# LLM provider API key (pi-ai reads these automatically)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456:ABC...

# Slack bot token
SLACK_BOT_TOKEN=xoxb-...

# Inngest keys (required for production/connect mode)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-prod-...

# Optional: restrict to specific Telegram chat IDs (comma-separated)
TELEGRAM_ALLOWED_CHATS=

# Optional: customize the agent
AGENT_NAME=Utah
AGENT_MODEL=openai/gpt-oss-20b
LLM_PROVIDER=anthropic
AGENT_WORKSPACE=./workspace

# Optional: OpenAI-compatible base URL (e.g. Groq, Ollama, LiteLLM, vLLM)
# When set, creates a custom model pointing at this endpoint instead of using pi-ai's registry.
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Heartbeat: cron schedule for memory maintenance (default: every 30min)
# HEARTBEAT_CRON=*/30 * * * *

# How many days to keep daily log files before pruning (default: 30)
# MEMORY_RETENTION_DAYS=30

# Log level for pino logger (default: info)
# LOG_LEVEL=debug

# Set to 1 for local dev server mode (uses serve() instead of connect())
# INNGEST_DEV=1

# Optional Scoring settings
SCORING_ENABLED=true
SCORING_PROVIDER=anthropic
SCORING_MODEL=openai/gpt-oss-120b

# Disable Prompt Versioning (default to SOUL.md)
# PROMPT_VERSIONING_ENABLED=false

# Evaluation Pipeline settings
# EVALUATION_CRON=0 */6 * * *
# EVAL_MIN_DATA_POINTS=10
# EVAL_TARGET_COMPOSITE=7.0
# EVAL_MAX_VERSIONS=5
# EVAL_NEW_VERSION_WEIGHT=0.5
# EVAL_PROMOTION_TRAFFIC=0.6
# EVAL_PROMOTION_SCORE_GAP=0.3
# EVAL_SIGNIFICANT_GAP=1.0
