{
  "name": "inngest-agent-example",
  "version": "0.1.0",
  "description": "A durable AI agent built with Inngest + pi-ai — think/act/observe loop, Telegram integration, local development via connect()",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "INNGEST_DEV=1 node --watch --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/worker.ts",
    "start": "node --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/worker.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.54.2",
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "^0.54.0",
    "@sinclair/typebox": "^0.34.0",
    "inngest": "4.0.0-alpha.6",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=10"
  }
}
